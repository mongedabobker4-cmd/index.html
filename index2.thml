<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Digital Business Card</title>
  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #d9d0c3;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
    }

    .card {
      width: 420px;
      background: #d9d0c3;
      box-shadow: 0 10px 25px rgba(0,0,0,0.15);
      border-radius: 0;
      overflow: hidden;
    }

    .header {
      background: #5a4332;
      padding: 25px;
      height: 90px;
    }

    .header img {
      width: 70px;
    }

    .content {
      text-align: center;
      padding: 60px 35px;
      color: #3e2512;
    }

    h1 {
      font-size: 34px;
      margin-bottom: 25px;
      font-weight: bold;
    }

    h2 {
      font-size: 28px;
      margin-bottom: 35px;
      font-weight: bold;
    }

    .line {
      width: 180px;
      height: 2px;
      background: #9f8f7e;
      margin: 30px auto;
    }

    .info a {
      display: block;
      margin: 18px 0;
      font-size: 22px;
      font-weight: bold;
      color: #3e2512;
      text-decoration: none;
    }

    .info a:hover {
      text-decoration: underline;
    }

    .address {
      margin-top: 28px;
      font-size: 20px;
      line-height: 1.5;
    }
  </style>
</head>
<body>
  <div class="card">
    <div class="header">
      <img src="logo.png" alt="logo">
    </div>

    <div class="content">
      <h1>Noor AL-Da’em</h1>
      <h2>Branches Manager</h2>
      <div class="line"></div>

      <div class="info">
        <a href="tel:0541756887">0541756887</a>
        <a href="mailto:info@alawalgruop.com">info@alawalgruop.com</a>
        <a class="address" href="https://maps.google.com/?q=Al Barakah St, Al Falah, Riyadh 13314" target="_blank">
          Al Barakah St, Al Falah, Riyadh 13314
        </a>
      </div>
    </div>
  </div>
</body>
</html>
